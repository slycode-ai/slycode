{
  "name": "@slycode/slycode",
  "version": "0.4.1",
  "description": "AI-powered development workspace with kanban, terminal bridge, and skill management",
  "bin": {
    "slycode": "bin/slycode.js",
    "sly-atlas": "bin/sly-atlas.js",
    "sly-kanban": "bin/sly-kanban.js",
    "sly-messaging": "bin/sly-messaging.js",
    "sly-scaffold": "bin/sly-scaffold.js"
  },
  "main": "./lib/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin/",
    "data/",
    "lib/",
    "dist/",
    "scripts/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "preinstall": "node scripts/preinstall.js",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path'); try{const d=p.join(p.dirname(require.resolve('node-pty/package.json')),'prebuilds'); fs.readdirSync(d).filter(f=>f.startsWith('darwin')).forEach(f=>{const h=p.join(d,f,'spawn-helper'); if(fs.existsSync(h)){fs.chmodSync(h,0o755);console.log('[slycode] Fixed node-pty spawn-helper permissions:',h)}})}catch{}\""
  },
  "keywords": [
    "slycode",
    "claude",
    "ai",
    "development",
    "workspace",
    "kanban",
    "terminal"
  ],
  "author": "Greg Atkins <support@slycode.ai> (https://github.com/slycode-ai)",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slycode-ai/slycode.git"
  },
  "homepage": "https://github.com/slycode-ai/slycode#readme",
  "bugs": {
    "url": "https://github.com/slycode-ai/slycode/issues"
  },
  "dependencies": {
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "node-pty": "1.2.0-beta.12",
    "openai": "^4.78.0",
    "ws": "^8.20.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "fast-xml-builder": "1.1.9",
    "path-to-regexp": "0.1.13",
    "form-data": "^4.0.6"
  }
}
