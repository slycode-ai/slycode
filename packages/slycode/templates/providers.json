{
  "schemaVersion": 1,
  "providers": {
    "claude": {
      "id": "claude",
      "displayName": "Claude Code",
      "command": "claude",
      "install": "npm i -g @anthropic-ai/claude-code",
      "permissions": {
        "flag": "--dangerously-skip-permissions",
        "label": "Skip permissions",
        "default": true
      },
      "resume": {
        "supported": true,
        "type": "flag",
        "flag": "--resume",
        "detectSession": true,
        "sessionDir": "~/.claude/projects/"
      },
      "prompt": {
        "type": "positional"
      },
      "instructionFile": "CLAUDE.md",
      "model": {
        "flag": "--model",
        "available": [
          {
            "id": "fable",
            "label": "Fable",
            "description": "Most intelligent, Mythos-class"
          },
          {
            "id": "sonnet",
            "label": "Sonnet",
            "description": "Fast, capable"
          },
          {
            "id": "opus",
            "label": "Opus",
            "description": "Most capable"
          },
          {
            "id": "haiku",
            "label": "Haiku",
            "description": "Fastest, lightweight"
          }
        ]
      }
    },
    "codex": {
      "id": "codex",
      "displayName": "Codex CLI",
      "command": "codex",
      "install": "npm i -g @openai/codex",
      "permissions": {
        "flag": "--yolo",
        "label": "YOLO mode",
        "default": true
      },
      "resume": {
        "supported": true,
        "type": "subcommand",
        "subcommand": "resume",
        "lastFlag": "--last",
        "detectSession": true
      },
      "prompt": {
        "type": "positional"
      },
      "instructionFile": "AGENTS.md",
      "altInstructionFile": "CODEX.md",
      "model": {
        "flag": "-m",
        "available": [
          {
            "id": "gpt-5.4",
            "label": "GPT-5.4",
            "description": "Latest frontier agentic coding model"
          },
          {
            "id": "gpt-5.4-mini",
            "label": "GPT-5.4 Mini",
            "description": "Smaller frontier agentic coding model"
          },
          {
            "id": "gpt-5.3-codex",
            "label": "GPT-5.3 Codex",
            "description": "Codex-optimized agentic coding model"
          },
          {
            "id": "gpt-5.2-codex",
            "label": "GPT-5.2 Codex",
            "description": "Frontier agentic coding model"
          }
        ]
      }
    },
    "gemini": {
      "id": "gemini",
      "displayName": "Gemini CLI",
      "command": "gemini",
      "install": "npm i -g @google/gemini-cli",
      "permissions": {
        "flag": "--yolo",
        "label": "YOLO mode",
        "default": true
      },
      "resume": {
        "supported": true,
        "type": "flag",
        "flag": "--resume",
        "detectSession": true
      },
      "prompt": {
        "type": "flag",
        "interactive": "-i",
        "nonInteractive": "-p"
      },
      "instructionFile": "GEMINI.md",
      "model": {
        "flag": "-m",
        "available": [
          {
            "id": "gemini-3-flash-preview",
            "label": "3 Flash Preview",
            "description": "Latest preview model"
          },
          {
            "id": "gemini-3.1-flash-lite-preview",
            "label": "3.1 Flash Lite Preview",
            "description": "Lightweight preview model"
          },
          {
            "id": "gemini-2.5-flash",
            "label": "2.5 Flash",
            "description": "Fast, capable"
          },
          {
            "id": "gemini-2.5-flash-lite",
            "label": "2.5 Flash Lite",
            "description": "Lightweight, efficient"
          }
        ]
      }
    }
  },
  "defaults": {
    "global": {
      "provider": "claude",
      "skipPermissions": true
    }
  }
}
